# ─────────────────────────────────────────────
# MemoCore environment configuration
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control!
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_NAME=MemoCore
DEBUG=false

# ── Security ─────────────────────────────────
# Only messages from this phone number are processed.
# Use E.164 format, e.g. +12025551234
ALLOWED_USER_PHONE=+90576750491

# ── OpenRouter (DeepSeek) ────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-beb4592dd67c4fdb9ec47d2ac279f46d

# ── Database ─────────────────────────────────
# Development (SQLite — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./memocore.db

# Production (PostgreSQL — uncomment & fill in):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/memocore

# ── Scheduler ────────────────────────────────
# How often (seconds) to check for upcoming events
REMINDER_CHECK_INTERVAL_SECONDS=60
# How many minutes before an event to send a reminder
REMINDER_LEAD_TIME_MINUTES=15
